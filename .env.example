# YouTube Live stream key
# Find it at: YouTube Studio → Go Live → Stream → Stream Key
YOUTUBE_STREAM_KEY=your-youtube-stream-key

# Facebook Live stream key
# Find it at: Facebook Live Producer → Go Live → Stream Key
FACEBOOK_STREAM_KEY=your-facebook-stream-key

# Instagram Live stream key and RTMP bridge host
# Instagram doesn't natively support RTMP ingest, so you need a third-party
# RTMP bridge (e.g., YellowDuck, Loopback). Set the bridge host and key here.
INSTAGRAM_STREAM_KEY=your-instagram-stream-key
INSTAGRAM_RTMP_HOST=your-instagram-rtmp-bridge-host
